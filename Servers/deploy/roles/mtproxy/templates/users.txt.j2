# {{ ansible_managed }}
# ─────────────────────────────────────────────────────────────────────
# MTProxy (mtg) — реестр выданного доступа
# ─────────────────────────────────────────────────────────────────────
#
# Этот файл НЕ используется mtg — он для администратора.
# mtg v2 использует единый секрет: все пользователи подключаются одним и тем же.
#
# ЗАЧЕМ ЭТОТ ФАЙЛ:
#   При ротации секрета (компрометация, отзыв доступа) администратор
#   должен разослать новую ссылку ВСЕМ оставшимся пользователям.
#   Этот реестр — единственный источник информации о том, кому отправлять.
#
# ПРОЦЕДУРА РОТАЦИИ:
#   1. Изменить mtproxy_secret в group_vars/all.yml
#   2. Удалить отозванного пользователя из mtproxy_users
#   3. Применить playbook (--tags mtproxy)
#   4. Отправить новую ссылку каждому оставшемуся по его Telegram-аккаунту
#
# ─────────────────────────────────────────────────────────────────────
# ТЕКУЩИЕ РЕКВИЗИТЫ ПОДКЛЮЧЕНИЯ
# ─────────────────────────────────────────────────────────────────────
# Secret: {{ mtproxy_secret_resolved }}
{% set proxy_server = mtproxy_hostname if (mtproxy_hostname is defined and mtproxy_hostname != "") else (keepalived_vip if keepalived_vip is defined else hostvars[groups['access_proxies'][0]]['ansible_host']) %}
# Ссылка: tg://proxy?server={{ proxy_server }}&port=443&secret={{ mtproxy_secret_resolved }}
#
# ─────────────────────────────────────────────────────────────────────
# ФОРМАТ ЗАПИСЕЙ (источник: group_vars/all.yml → mtproxy_users)
# ─────────────────────────────────────────────────────────────────────
#
#   name     — Фамилия Имя или ник. Для однозначной идентификации человека.
#              Пример: "Петров Иван", "devops-bot"
#
#   telegram — Telegram @username получателя. Именно на этот аккаунт
#              администратор отправит новую ссылку при ротации секрета.
#              Формат: @username (как в профиле Telegram).
#              Пример: "@ipetrov", "@devops_team_bot"
#
#   granted  — Дата выдачи доступа в формате YYYY-MM-DD.
#              Нужна для аудита: как давно у человека доступ,
#              не истёк ли срок временного доступа.
#              Пример: "2025-06-01"
#
#   note     — Роль/причина/срок. Почему выдан доступ и когда отозвать.
#              Пример: "Сисадмин, бессрочно"
#              Пример: "Подрядчик, до 2025-09-01"
#              Пример: "Тест, удалить после проверки"
#
# ─────────────────────────────────────────────────────────────────────
# РЕЕСТР
# ─────────────────────────────────────────────────────────────────────
# Имя | Telegram | Дата выдачи | Заметка
{% for user in mtproxy_users %}
{{ user.name }} | {{ user.telegram | default('-') }} | {{ user.granted | default('-') }} | {{ user.note | default('') }}
{% endfor %}
