# {{ ansible_managed }}
# MTProxy TLS 1.3 termination (stream context, co-deployment safe)
#
# Architecture: SNI router on port 443 (shared with Matrix/other projects)
# routes MTProxy traffic to this local TLS terminator.
# TLS is terminated here; decrypted stream forwarded to mtg daemon.

upstream mtproxy_tls_term {
    server 127.0.0.1:{{ mtproxy_tls_port | default(4443) }};
}

server {
    listen 127.0.0.1:{{ mtproxy_tls_port | default(4443) }} ssl proxy_protocol;

    ssl_certificate     /etc/nginx/ssl/mtproxy.crt;
    ssl_certificate_key /etc/nginx/ssl/mtproxy.key;
    ssl_protocols       TLSv1.3;

    proxy_pass 127.0.0.1:{{ mtproxy_local_port }};

    # Timeouts: 60s idle for MTProxy (Telegram has its own keepalive)
    proxy_connect_timeout 10s;
    proxy_timeout 60s;

    # TCP keepalive: detect dead peers via kernel probes
    proxy_socket_keepalive on;
}
