# Keepalived Configuration - RU Proxy
# Managed by Ansible - DO NOT EDIT MANUALLY
# Host: {{ inventory_hostname }} ({{ ansible_host }})

global_defs {
    router_id {{ keepalived_router_id | default('AI_PROXY_RU') }}
    script_user root
    enable_script_security
}

# Проверка доступности Squid с автоперезапуском
# Скрипт: killall -0 squid (проверка) → systemctl restart squid (при падении)
# Cooldown {{ keepalived_restart_cooldown | default(30) }}s между попытками рестарта
vrrp_script check_squid {
    script "/etc/keepalived/check_and_restart_squid.sh"
    interval 2
    weight -20
    fall 3
    rise 2
}

vrrp_instance VI_SQUID {
    state {{ keepalived_state }}
    interface {{ keepalived_interface | default(ansible_default_ipv4.interface) }}
    virtual_router_id {{ keepalived_vrid | default(51) }}

    priority {{ keepalived_priority }}

    advert_int 1

    authentication {
        auth_type PASS
        auth_pass {{ keepalived_auth_pass | default('ExAmPlEpAsS') }}
    }

    virtual_ipaddress {
        {{ keepalived_vip }}/{{ keepalived_vip_prefix | default(24) }}
    }

    track_script {
        check_squid
    }

{% if keepalived_notify_script is defined %}
    notify_master "{{ keepalived_notify_script }} master"
    notify_backup "{{ keepalived_notify_script }} backup"
    notify_fault  "{{ keepalived_notify_script }} fault"
{% endif %}
}
